{
  "name": "mppx-hedera",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Native Hedera payment method for Machine Payments Protocol (MPP). Charge + session intents, no facilitator.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mpp",
    "mppx",
    "hedera",
    "http-402",
    "payments",
    "agentic",
    "usdc",
    "stablecoin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tomrowbo/mppx-hedera"
  },
  "peerDependencies": {
    "mppx": ">=0.5.9",
    "viem": ">=2.21.0"
  },
  "devDependencies": {
    "mppx": "latest",
    "tsup": "^8.5.1",
    "typescript": "latest",
    "viem": "latest",
    "zod": "latest"
  }
}
