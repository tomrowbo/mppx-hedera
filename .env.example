# ─── Hedera (testnet) ──────────────────────────────────────────────
# Account that signs USDC-H transfers (client-side signing in the browser).
# NOTE: We prefix with VITE_ because the browser bundle reads via import.meta.env.
# This is TESTNET ONLY — the private key ends up in the browser bundle.
#
# ⚠️ HEDERA ADDRESS RULE — read this before any derivations:
#   HTS tokens / contracts deployed by EOA     → LONG-ZERO form (hex of num, zero-padded)
#   ECDSA accounts (our operator, recipients)  → ECDSA ALIAS from Mirror Node evm_address
#   NEVER derive the operator's EVM address from its 0.0.X number — the long-zero form
#   points to a non-existent account. Always use HEDERA_EVM_ADDRESS from this file.
#   See docs/06-RISKS.md §R7f for the full rule.
HEDERA_ACCOUNT_ID=0.0.8569027
HEDERA_EVM_ADDRESS=0x0080f617e5f61f60d7b195dcc955287d4f8df1d0  # ECDSA alias — do NOT derive
HEDERA_PRIVATE_KEY=0x...                 # server side (for spike scripts only)
VITE_HEDERA_PRIVATE_KEY=0x...            # browser side (same value, VITE_ prefix required)

# Recipient — for the hackathon demo, SET THIS TO THE SAME ADDRESS AS THE SIGNER.
# USDC-H cycles back to the same account on each transfer, giving you unlimited
# dry runs on a small testnet balance. Hashscan still shows real HTS transfers.
# If you top up to 500+ USDC, you can use a separate recipient address.
HEDERA_RECIPIENT_ADDRESS=0x0080f617e5f61f60d7b195dcc955287d4f8df1d0

# Endpoints
HEDERA_RPC_URL=https://testnet.hashio.io/api
HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com/api/v1
HEDERA_CHAIN_ID=296

# USDC-H (HTS token exposed at long-zero EVM address)
HEDERA_USDC_ADDRESS=0x0000000000000000000000000000000000068cDa
HEDERA_USDC_DECIMALS=6

# ─── MPP / mppx ────────────────────────────────────────────────────
MPP_SECRET_KEY=                          # 32-byte random for Mppx.create

# ─── Stripe (test mode) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...            # server side
VITE_STRIPE_PUBLIC_KEY=pk_test_...       # browser side (VITE_ prefix required)
